#:import get_color_from_hex kivy.utils.get_color_from_hex

MDBoxLayout:
    orientation: "vertical"
    md_bg_color: "#0D0D0D"
    
    ScreenManager:
        id: screen_manager
        
        # ========== SPLASH SCREEN (LOADING) ==========
        MDScreen:
            name: "loading"
            
            MDFloatLayout:
                md_bg_color: "#0D0D0D"
                
                MDBoxLayout:
                    orientation: "vertical"
                    size_hint: None, None
                    size: "250dp", "200dp"
                    pos_hint: {"center_x": 0.5, "center_y": 0.5}
                    spacing: "30dp"
                    
                    # Logo Image
                    Image:
                        source: "assets/logo.png"
                        size_hint: None, None
                        size: "120dp", "120dp"
                        pos_hint: {"center_x": 0.5}
                        allow_stretch: True
                        keep_ratio: True
                    
                    # App Name
                    MDLabel:
                        text: "AnyLoad"
                        font_style: "H6"
                        theme_text_color: "Custom"
                        text_color: "#00D2A0"
                        halign: "center"
                        size_hint_y: None
                        height: "30dp"
                    
                    # Animated Dots (Canvas-based, no tofu)
                    MDBoxLayout:
                        orientation: "horizontal"
                        size_hint: None, None
                        size: "80dp", "20dp"
                        pos_hint: {"center_x": 0.5}
                        spacing: "10dp"
                        
                        Widget:
                            size_hint: None, None
                            size: "15dp", "15dp"
                            canvas:
                                Color:
                                    rgba: get_color_from_hex("#00D2A0") if app.splash_dot_index == 0 else get_color_from_hex("#333333")
                                Ellipse:
                                    pos: self.pos
                                    size: self.size
                        
                        Widget:
                            size_hint: None, None
                            size: "15dp", "15dp"
                            canvas:
                                Color:
                                    rgba: get_color_from_hex("#00D2A0") if app.splash_dot_index == 1 else get_color_from_hex("#333333")
                                Ellipse:
                                    pos: self.pos
                                    size: self.size
                        
                        Widget:
                            size_hint: None, None
                            size: "15dp", "15dp"
                            canvas:
                                Color:
                                    rgba: get_color_from_hex("#00D2A0") if app.splash_dot_index == 2 else get_color_from_hex("#333333")
                                Ellipse:
                                    pos: self.pos
                                    size: self.size
        
        # ========== HOME SCREEN ==========
        MDScreen:
            name: "home"
            
            MDBoxLayout:
                orientation: "vertical"
                md_bg_color: "#0D0D0D"
                
                # Top Bar (HORIZONTAL LAYOUT - FIX FOR VERTICAL BUG)
                MDBoxLayout:
                    orientation: "horizontal"
                    size_hint_y: None
                    height: "64dp"
                    padding: "16dp", "12dp"
                    md_bg_color: "#0D0D0D"
                    spacing: "12dp"
                    
                    MDLabel:
                        text: "ANYLOAD"
                        font_style: "H6"
                        theme_text_color: "Custom"
                        text_color: "#00D2A0"
                        size_hint_x: None
                        width: self.texture_size[0]
                        adaptive_width: True
                    
                    # Spinner Animation (Canvas-based, no tofu)
                    FloatLayout:
                        size_hint: None, None
                        size: "40dp", "40dp"
                        opacity: 1 if app.is_active_download else 0
                        
                        Widget:
                            size_hint: None, None
                            size: "40dp", "40dp"
                            pos_hint: {"center_x": 0.5, "center_y": 0.5}
                            canvas.before:
                                PushMatrix:
                                Rotate:
                                    angle: app.spinner_angle
                                    origin: self.center
                            canvas:
                                Color:
                                    rgba: get_color_from_hex("#00D2A0")
                                Ellipse:
                                    pos: self.x + 17, self.y + 30
                                    size: 6, 6
                                Ellipse:
                                    pos: self.x + 17, self.y + 17
                                    size: 6, 6
                                Ellipse:
                                    pos: self.x + 17, self.y + 4
                                    size: 6, 6
                            canvas.after:
                                PopMatrix:
                    
                    Widget:
                
                # Main Content
                ScrollView:
                    do_scroll_x: False
                    
                    MDBoxLayout:
                        orientation: "vertical"
                        adaptive_height: True
                        padding: "20dp"
                        spacing: "24dp"
                        
                        Widget:
                            size_hint_y: None
                            height: "10dp"
                        
                        # Premium "A" Logo Icon
                        MDFloatLayout:
                            size_hint_y: None
                            height: "100dp"
                            
                            Widget:
                                size_hint: None, None
                                size: "80dp", "80dp"
                                pos_hint: {"center_x": 0.5, "center_y": 0.5}
                                canvas:
                                    Color:
                                        rgba: get_color_from_hex("#00D2A0")
                                    RoundedRectangle:
                                        pos: self.pos
                                        size: self.size
                                        radius: [20]
                            
                            MDLabel:
                                text: "A"
                                font_style: "H6"
                                theme_text_color: "Custom"
                                text_color: "#0D0D0D"
                                halign: "center"
                                font_size: "40sp"
                                bold: True
                                pos_hint: {"center_x": 0.5, "center_y": 0.5}
                        
                        # URL Input Card (Rounded MDCard)
                        MDCard:
                            size_hint_y: None
                            height: "60dp"
                            md_bg_color: "#1A1A1A"
                            radius: [15]
                            elevation: 0
                            padding: "15dp", "10dp"
                            
                            MDBoxLayout:
                                orientation: "horizontal"
                                spacing: "10dp"
                                
                                TextInput:
                                    id: url_input
                                    hint_text: "Paste URL here..."
                                    background_color: 0, 0, 0, 0
                                    foreground_color: get_color_from_hex("#FFFFFF")
                                    hint_text_color: get_color_from_hex("#666666")
                                    cursor_color: get_color_from_hex("#00D2A0")
                                    font_size: "15sp"
                                    multiline: False
                                    padding: 5, 10
                                
                                MDIconButton:
                                    icon: "content-paste"
                                    theme_text_color: "Custom"
                                    text_color: "#00D2A0"
                                    pos_hint: {"center_y": 0.5}
                                    on_release: app.paste_from_clipboard()
                        
                        # Action Card 1: Auto Best Quality
                        MDCard:
                            size_hint_y: None
                            height: "70dp"
                            md_bg_color: "#1A1A1A"
                            radius: [15]
                            elevation: 0
                            ripple_behavior: True
                            
                            MDBoxLayout:
                                orientation: "horizontal"
                                padding: "20dp", "15dp"
                                spacing: "15dp"
                                
                                MDIcon:
                                    icon: "video"
                                    theme_text_color: "Custom"
                                    text_color: "#00D2A0"
                                    size_hint_x: None
                                    width: "30dp"
                                    font_size: "28sp"
                                
                                MDLabel:
                                    text: "Auto Best Quality"
                                    font_style: "Subtitle1"
                                    theme_text_color: "Custom"
                                    text_color: "#FFFFFF"
                                    adaptive_width: True
                        
                        # Action Card 2: Audio Only
                        MDCard:
                            size_hint_y: None
                            height: "70dp"
                            md_bg_color: "#1A1A1A"
                            radius: [15]
                            elevation: 0
                            ripple_behavior: True
                            
                            MDBoxLayout:
                                orientation: "horizontal"
                                padding: "20dp", "15dp"
                                spacing: "15dp"
                                
                                MDIcon:
                                    icon: "music"
                                    theme_text_color: "Custom"
                                    text_color: "#00D2A0"
                                    size_hint_x: None
                                    width: "30dp"
                                    font_size: "28sp"
                                
                                MDLabel:
                                    text: "Audio Only (MP3)"
                                    font_style: "Subtitle1"
                                    theme_text_color: "Custom"
                                    text_color: "#FFFFFF"
                                    adaptive_width: True
                        
                        # Action Card 3: Playlist Download
                        MDCard:
                            size_hint_y: None
                            height: "70dp"
                            md_bg_color: "#1A1A1A"
                            radius: [15]
                            elevation: 0
                            ripple_behavior: True
                            
                            MDBoxLayout:
                                orientation: "horizontal"
                                padding: "20dp", "15dp"
                                spacing: "15dp"
                                
                                MDIcon:
                                    icon: "playlist-play"
                                    theme_text_color: "Custom"
                                    text_color: "#00D2A0"
                                    size_hint_x: None
                                    width: "30dp"
                                    font_size: "28sp"
                                
                                MDLabel:
                                    text: "Playlist Download"
                                    font_style: "Subtitle1"
                                    theme_text_color: "Custom"
                                    text_color: "#FFFFFF"
                                    adaptive_width: True
                        
                        Widget:
                            size_hint_y: None
                            height: "20dp"
        
        # ========== TASKS SCREEN ==========
        MDScreen:
            name: "tasks"
            
            MDBoxLayout:
                orientation: "vertical"
                md_bg_color: "#0D0D0D"
                
                MDLabel:
                    text: "TASKS TAB"
                    halign: "center"
                    theme_text_color: "Custom"
                    text_color: "#00D2A0"
                    font_style: "H6"
        
        # ========== LIBRARY SCREEN ==========
        MDScreen:
            name: "library"
            
            MDBoxLayout:
                orientation: "vertical"
                md_bg_color: "#0D0D0D"
                
                MDLabel:
                    text: "LIBRARY TAB"
                    halign: "center"
                    theme_text_color: "Custom"
                    text_color: "#00D2A0"
                    font_style: "H6"
        
        # ========== CONFIGS SCREEN ==========
        MDScreen:
            name: "configs"
            
            MDBoxLayout:
                orientation: "vertical"
                md_bg_color: "#0D0D0D"
                
                MDLabel:
                    text: "CONFIGS TAB"
                    halign: "center"
                    theme_text_color: "Custom"
                    text_color: "#00D2A0"
                    font_style: "H6"
    
    # Bottom Navigation
    MDBottomNavigation:
        size_hint_y: None
        height: "56dp"
        md_bg_color: "#1A1A1A"
        text_color_active: "#00D2A0"
        text_color_normal: "#666666"
        
        MDBottomNavigationItem:
            name: "home"
            text: "Home"
            icon: "home"
            on_tab_press: screen_manager.current = "home"
        
        MDBottomNavigationItem:
            name: "tasks"
            text: "Tasks"
            icon: "download"
            on_tab_press: screen_manager.current = "tasks"
        
        MDBottomNavigationItem:
            name: "library"
            text: "Library"
            icon: "folder"
            on_tab_press: screen_manager.current = "library"
        
        MDBottomNavigationItem:
            name: "configs"
            text: "Configs"
            icon: "cog"
            on_tab_press: screen_manager.current = "configs"
