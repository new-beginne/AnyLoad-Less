#:import get_color_from_hex kivy.utils.get_color_from_hex

<TaskCard>:
    orientation: "vertical"
    spacing: "10dp"
    
    MDBoxLayout:
        orientation: "horizontal"
        size_hint_y: None
        height: "30dp"
        
        MDLabel:
            text: root.filename[:30] + "..." if len(root.filename) > 30 else root.filename
            font_style: "Subtitle1"
            theme_text_color: "Custom"
            text_color: "#FFFFFF"
            adaptive_width: True
        
        Widget:
        
        MDIconButton:
            icon: "pause" if not root.is_paused else "play"
            theme_text_color: "Custom"
            text_color: "#00D2A0"
            on_release: root.toggle_pause()
        
        MDIconButton:
            icon: "close"
            theme_text_color: "Custom"
            text_color: "#FF5555"
            on_release: root.cancel_download()
    
    MDProgressBar:
        value: root.progress
        color: get_color_from_hex("#00D2A0")
        size_hint_y: None
        height: "4dp"
    
    MDBoxLayout:
        orientation: "horizontal"
        size_hint_y: None
        height: "25dp"
        
        MDLabel:
            text: f"{int(root.progress)}%"
            font_style: "Caption"
            theme_text_color: "Custom"
            text_color: "#00D2A0"
            size_hint_x: None
            width: "50dp"
        
        MDLabel:
            text: f"{root.speed} • ETA: {root.eta}"
            font_style: "Caption"
            theme_text_color: "Custom"
            text_color: "#999999"

<LibraryCard>:
    orientation: "vertical"
    
    MDFloatLayout:
        size_hint_y: 0.7
        
        Image:
            source: root.thumbnail
            size_hint: 1, 1
            allow_stretch: True
            keep_ratio: True
        
        MDFloatLayout:
            size_hint: None, None
            size: "50dp", "50dp"
            pos_hint: {"center_x": 0.5, "center_y": 0.5}
            
            Widget:
                canvas:
                    Color:
                        rgba: get_color_from_hex("#00D2A0")
                    Ellipse:
                        pos: self.pos
                        size: self.size
            
            MDIcon:
                icon: "play"
                theme_text_color: "Custom"
                text_color: "#0D0D0D"
                font_size: "30sp"
                pos_hint: {"center_x": 0.55, "center_y": 0.5}
    
    MDBoxLayout:
        orientation: "horizontal"
        size_hint_y: 0.3
        padding: "10dp"
        spacing: "5dp"
        
        MDLabel:
            text: root.filename[:25] + "..." if len(root.filename) > 25 else root.filename
            font_style: "Caption"
            theme_text_color: "Custom"
            text_color: "#FFFFFF"
        
        MDIconButton:
            icon: "dots-vertical"
            theme_text_color: "Custom"
            text_color: "#00D2A0"
            size_hint_x: None
            width: "30dp"
            on_release: root.show_menu(self)

MDNavigationLayout:
    
    ScreenManager:
        id: screen_manager
        
        # ========== SPLASH SCREEN ==========
        MDScreen:
            name: "loading"
            
            MDFloatLayout:
                md_bg_color: "#0D0D0D"
                
                MDBoxLayout:
                    orientation: "vertical"
                    size_hint: None, None
                    size: "250dp", "200dp"
                    pos_hint: {"center_x": 0.5, "center_y": 0.5}
                    spacing: "30dp"
                    
                    Image:
                        source: "assets/logo.png"
                        size_hint: None, None
                        size: "120dp", "120dp"
                        pos_hint: {"center_x": 0.5}
                        allow_stretch: True
                        keep_ratio: True
                    
                    MDLabel:
                        text: "AnyLoad"
                        font_style: "H6"
                        theme_text_color: "Custom"
                        text_color: "#00D2A0"
                        halign: "center"
                        size_hint_y: None
                        height: "30dp"
                    
                    MDBoxLayout:
                        orientation: "horizontal"
                        size_hint: None, None
                        size: "80dp", "20dp"
                        pos_hint: {"center_x": 0.5}
                        spacing: "10dp"
                        
                        Widget:
                            size_hint: None, None
                            size: "15dp", "15dp"
                            canvas:
                                Color:
                                    rgba: get_color_from_hex("#00D2A0") if app.splash_dot_index == 0 else get_color_from_hex("#333333")
                                Ellipse:
                                    pos: self.pos
                                    size: self.size
                        
                        Widget:
                            size_hint: None, None
                            size: "15dp", "15dp"
                            canvas:
                                Color:
                                    rgba: get_color_from_hex("#00D2A0") if app.splash_dot_index == 1 else get_color_from_hex("#333333")
                                Ellipse:
                                    pos: self.pos
                                    size: self.size
                        
                        Widget:
                            size_hint: None, None
                            size: "15dp", "15dp"
                            canvas:
                                Color:
                                    rgba: get_color_from_hex("#00D2A0") if app.splash_dot_index == 2 else get_color_from_hex("#333333")
                                Ellipse:
                                    pos: self.pos
                                    size: self.size
        
        # ========== HOME SCREEN ==========
        MDScreen:
            name: "home"
            
            MDBoxLayout:
                orientation: "vertical"
                md_bg_color: "#0D0D0D"
                
                # Top App Bar
                MDBoxLayout:
                    orientation: "horizontal"
                    size_hint_y: None
                    height: "64dp"
                    padding: "16dp", "12dp"
                    md_bg_color: "#0D0D0D"
                    spacing: "12dp"
                    
                    MDLabel:
                        text: "ANYLOAD"
                        font_style: "H6"
                        theme_text_color: "Custom"
                        text_color: "#FFFFFF"
                        size_hint_x: None
                        width: self.texture_size[0]
                        adaptive_width: True
                    
                    Widget:
                    
                    MDIconButton:
                        icon: "menu"
                        theme_text_color: "Custom"
                        text_color: "#FFFFFF"
                        on_release: app.toggle_nav_drawer()
                
                # Animated Dots
                MDBoxLayout:
                    size_hint_y: None
                    height: "20dp"
                    padding: "16dp", "0dp"
                    
                    MDBoxLayout:
                        orientation: "horizontal"
                        size_hint: None, None
                        size: "60dp", "15dp"
                        spacing: "8dp"
                        
                        Widget:
                            size_hint: None, None
                            size: "10dp", "10dp"
                            canvas:
                                Color:
                                    rgba: get_color_from_hex("#00D2A0") if app.is_active_download else get_color_from_hex("#333333")
                                Ellipse:
                                    pos: self.pos
                                    size: self.size
                        
                        Widget:
                            size_hint: None, None
                            size: "10dp", "10dp"
                            canvas:
                                Color:
                                    rgba: get_color_from_hex("#00D2A0") if app.is_active_download else get_color_from_hex("#333333")
                                Ellipse:
                                    pos: self.pos
                                    size: self.size
                        
                        Widget:
                            size_hint: None, None
                            size: "10dp", "10dp"
                            canvas:
                                Color:
                                    rgba: get_color_from_hex("#00D2A0") if app.is_active_download else get_color_from_hex("#333333")
                                Ellipse:
                                    pos: self.pos
                                    size: self.size
                    
                    Widget:
                
                # Main Content
                ScrollView:
                    do_scroll_x: False
                    
                    MDBoxLayout:
                        orientation: "vertical"
                        adaptive_height: True
                        padding: "20dp"
                        spacing: "30dp"
                        
                        Widget:
                            size_hint_y: None
                            height: "30dp"
                        
                        # Logo and Title
                        MDBoxLayout:
                            orientation: "vertical"
                            size_hint_y: None
                            height: "150dp"
                            spacing: "15dp"
                            
                            Image:
                                source: "assets/logo.png"
                                size_hint: None, None
                                size: "100dp", "100dp"
                                pos_hint: {"center_x": 0.5}
                                allow_stretch: True
                                keep_ratio: True
                            
                            MDLabel:
                                text: "ANYLOAD"
                                font_style: "H6"
                                theme_text_color: "Custom"
                                text_color: "#00D2A0"
                                halign: "center"
                                size_hint_y: None
                                height: "30dp"
                        
                        # URL Input (Pill Shape)
                        MDCard:
                            size_hint_y: None
                            height: "55dp"
                            md_bg_color: "#2A2A2A"
                            radius: [30, 30, 30, 30]
                            elevation: 0
                            padding: "20dp", "10dp"
                            
                            MDBoxLayout:
                                orientation: "horizontal"
                                spacing: "10dp"
                                
                                TextInput:
                                    id: url_input
                                    hint_text: "Paste video link here..."
                                    background_color: 0, 0, 0, 0
                                    foreground_color: get_color_from_hex("#FFFFFF")
                                    hint_text_color: get_color_from_hex("#666666")
                                    cursor_color: get_color_from_hex("#00D2A0")
                                    font_size: "15sp"
                                    multiline: False
                                    padding: 5, 10
                                
                                MDIconButton:
                                    icon: "content-paste"
                                    theme_text_color: "Custom"
                                    text_color: "#00D2A0"
                                    pos_hint: {"center_y": 0.5}
                                    on_release: app.paste_from_clipboard()
                        
                        # Teal Pill Buttons
                        MDRaisedButton:
                            text: "  Auto Best Quality"
                            icon: "play-box-outline"
                            md_bg_color: "#00D2A0"
                            theme_text_color: "Custom"
                            text_color: "#0D0D0D"
                            font_style: "Subtitle1"
                            size_hint_y: None
                            height: "55dp"
                            on_release: app.download_video()
                        
                        MDRaisedButton:
                            text: "  Audio Only"
                            icon: "music-note"
                            md_bg_color: "#00D2A0"
                            theme_text_color: "Custom"
                            text_color: "#0D0D0D"
                            font_style: "Subtitle1"
                            size_hint_y: None
                            height: "55dp"
                            on_release: app.download_audio()
                        
                        MDRaisedButton:
                            text: "  Playlist Download"
                            icon: "playlist-play"
                            md_bg_color: "#00D2A0"
                            theme_text_color: "Custom"
                            text_color: "#0D0D0D"
                            font_style: "Subtitle1"
                            size_hint_y: None
                            height: "55dp"
                            on_release: app.download_playlist()
                        
                        Widget:
                            size_hint_y: None
                            height: "20dp"
        
        # ========== TASKS SCREEN ==========
        MDScreen:
            name: "tasks"
            
            MDBoxLayout:
                orientation: "vertical"
                md_bg_color: "#0D0D0D"
                
                MDBoxLayout:
                    orientation: "horizontal"
                    size_hint_y: None
                    height: "64dp"
                    padding: "20dp", "12dp"
                    
                    MDLabel:
                        text: "Active Downloads"
                        font_style: "H6"
                        theme_text_color: "Custom"
                        text_color: "#00D2A0"
                
                ScrollView:
                    do_scroll_x: False
                    
                    MDBoxLayout:
                        id: task_container
                        orientation: "vertical"
                        adaptive_height: True
                        padding: "20dp"
                        spacing: "15dp"
        
        # ========== LIBRARY SCREEN ==========
        MDScreen:
            name: "library"
            
            MDBoxLayout:
                orientation: "vertical"
                md_bg_color: "#0D0D0D"
                
                MDBoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    height: "110dp"
                    padding: "20dp", "12dp"
                    spacing: "10dp"
                    
                    MDLabel:
                        text: "Library"
                        font_style: "H6"
                        theme_text_color: "Custom"
                        text_color: "#00D2A0"
                        size_hint_y: None
                        height: "30dp"
                    
                    MDBoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: "40dp"
                        spacing: "10dp"
                        
                        MDRaisedButton:
                            text: "VIDEOS"
                            md_bg_color: "#00D2A0" if app.library_filter == "videos" else "#1A1A1A"
                            theme_text_color: "Custom"
                            text_color: "#0D0D0D" if app.library_filter == "videos" else "#FFFFFF"
                            on_release: app.filter_library("videos")
                        
                        MDRaisedButton:
                            text: "AUDIO"
                            md_bg_color: "#00D2A0" if app.library_filter == "audio" else "#1A1A1A"
                            theme_text_color: "Custom"
                            text_color: "#0D0D0D" if app.library_filter == "audio" else "#FFFFFF"
                            on_release: app.filter_library("audio")
                        
                        MDRaisedButton:
                            text: "PLAYLISTS"
                            md_bg_color: "#00D2A0" if app.library_filter == "playlists" else "#1A1A1A"
                            theme_text_color: "Custom"
                            text_color: "#0D0D0D" if app.library_filter == "playlists" else "#FFFFFF"
                            on_release: app.filter_library("playlists")
                
                ScrollView:
                    do_scroll_x: False
                    
                    MDGridLayout:
                        id: library_container
                        cols: 2
                        adaptive_height: True
                        padding: "20dp"
                        spacing: "15dp"
        
        # ========== CONFIGS SCREEN ==========
        MDScreen:
            name: "configs"
            
            MDBoxLayout:
                orientation: "vertical"
                md_bg_color: "#0D0D0D"
                
                ScrollView:
                    do_scroll_x: False
                    
                    MDBoxLayout:
                        orientation: "vertical"
                        adaptive_height: True
                        padding: "20dp"
                        spacing: "30dp"
                        
                        Widget:
                            size_hint_y: None
                            height: "20dp"
                        
                        MDBoxLayout:
                            orientation: "vertical"
                            size_hint_y: None
                            height: "180dp"
                            spacing: "15dp"
                            
                            Image:
                                source: "assets/logo.png"
                                size_hint: None, None
                                size: "100dp", "100dp"
                                pos_hint: {"center_x": 0.5}
                                allow_stretch: True
                                keep_ratio: True
                            
                            MDLabel:
                                text: "AnyLoad v1.1"
                                font_style: "H6"
                                theme_text_color: "Custom"
                                text_color: "#00D2A0"
                                halign: "center"
                                size_hint_y: None
                                height: "30dp"
                            
                            MDLabel:
                                text: "Download Anything. Anytime."
                                font_style: "Caption"
                                theme_text_color: "Custom"
                                text_color: "#999999"
                                halign: "center"
                                size_hint_y: None
                                height: "20dp"
                        
                        MDCard:
                            size_hint_y: None
                            height: "280dp"
                            md_bg_color: "#1A1A1A"
                            radius: [15, 15, 15, 15]
                            elevation: 0
                            padding: "20dp"
                            
                            MDBoxLayout:
                                orientation: "vertical"
                                spacing: "25dp"
                                
                                MDBoxLayout:
                                    orientation: "vertical"
                                    size_hint_y: None
                                    height: "70dp"
                                    spacing: "10dp"
                                    
                                    MDBoxLayout:
                                        orientation: "horizontal"
                                        size_hint_y: None
                                        height: "25dp"
                                        
                                        MDLabel:
                                            text: "Max Concurrent Downloads"
                                            font_style: "Subtitle1"
                                            theme_text_color: "Custom"
                                            text_color: "#FFFFFF"
                                        
                                        MDLabel:
                                            text: str(int(app.max_downloads))
                                            font_style: "Subtitle1"
                                            theme_text_color: "Custom"
                                            text_color: "#00D2A0"
                                            size_hint_x: None
                                            width: "30dp"
                                    
                                    MDSlider:
                                        min: 1
                                        max: 5
                                        value: app.max_downloads
                                        color: get_color_from_hex("#00D2A0")
                                        on_value: app.max_downloads = self.value
                                
                                MDBoxLayout:
                                    orientation: "horizontal"
                                    size_hint_y: None
                                    height: "50dp"
                                    
                                    MDLabel:
                                        text: "Download Only on Wi-Fi"
                                        font_style: "Subtitle1"
                                        theme_text_color: "Custom"
                                        text_color: "#FFFFFF"
                                    
                                    MDSwitch:
                                        active: app.wifi_only
                                        thumb_color_active: get_color_from_hex("#00D2A0")
                                        on_active: app.wifi_only = self.active
                                        pos_hint: {"center_y": 0.5}
                                
                                MDBoxLayout:
                                    orientation: "vertical"
                                    size_hint_y: None
                                    height: "90dp"
                                    spacing: "10dp"
                                    
                                    MDLabel:
                                        text: "Download Path"
                                        font_style: "Subtitle1"
                                        theme_text_color: "Custom"
                                        text_color: "#FFFFFF"
                                        size_hint_y: None
                                        height: "25dp"
                                    
                                    MDLabel:
                                        text: app.download_path
                                        font_style: "Caption"
                                        theme_text_color: "Custom"
                                        text_color: "#999999"
                                        size_hint_y: None
                                        height: "20dp"
                                    
                                    MDRaisedButton:
                                        text: "Change Path"
                                        md_bg_color: "#00D2A0"
                                        theme_text_color: "Custom"
                                        text_color: "#0D0D0D"
                                        size_hint: None, None
                                        size: "150dp", "40dp"
                                        on_release: app.change_download_path()
                        
                        Widget:
                            size_hint_y: None
                            height: "20dp"
    
    # Right-Side Navigation Drawer
    MDNavigationDrawer:
        id: nav_drawer
        anchor: "right"
        md_bg_color: "#1A1A1A"
        
        MDBoxLayout:
            orientation: "vertical"
            padding: "20dp"
            spacing: "20dp"
            
            MDLabel:
                text: "Menu"
                font_style: "H6"
                theme_text_color: "Custom"
                text_color: "#00D2A0"
                size_hint_y: None
                height: "40dp"
            
            MDRaisedButton:
                text: "About AnyLoad"
                md_bg_color: "#2A2A2A"
                theme_text_color: "Custom"
                text_color: "#FFFFFF"
                size_hint_y: None
                height: "50dp"
                on_release: app.menu_action("about")
            
            MDRaisedButton:
                text: "Privacy Policy"
                md_bg_color: "#2A2A2A"
                theme_text_color: "Custom"
                text_color: "#FFFFFF"
                size_hint_y: None
                height: "50dp"
                on_release: app.menu_action("privacy")
            
            MDRaisedButton:
                text: "App Version (v1.1)"
                md_bg_color: "#2A2A2A"
                theme_text_color: "Custom"
                text_color: "#FFFFFF"
                size_hint_y: None
                height: "50dp"
                on_release: app.menu_action("version")
            
            Widget:

# Bottom Navigation
MDBottomNavigation:
    md_bg_color: "#1A1A1A"
    text_color_active: "#00D2A0"
    text_color_normal: "#666666"
    
    MDBottomNavigationItem:
        name: "home"
        text: "Home"
        icon: "home"
        on_tab_press: screen_manager.current = "home"
    
    MDBottomNavigationItem:
        name: "tasks"
        text: "Tasks"
        icon: "download"
        on_tab_press: screen_manager.current = "tasks"
    
    MDBottomNavigationItem:
        name: "library"
        text: "Library"
        icon: "video"
        on_tab_press: screen_manager.current = "library"
    
    MDBottomNavigationItem:
        name: "configs"
        text: "Configs"
        icon: "cog"
        on_tab_press: screen_manager.current = "configs"
