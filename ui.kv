# ui.kv
#:import get_color_from_hex kivy.utils.get_color_from_hex

MDBoxLayout:
    orientation: "vertical"
    md_bg_color: "#0D0D0D" # তোর স্ক্রিনশটের ডার্ক ব্যাকগ্রাউন্ড
    
    # --- Top App Bar ---
    MDBoxLayout:
        size_hint_y: None
        height: "70dp"
        padding: ["20dp", "10dp", "20dp", "5dp"]
        md_bg_color: "#0D0D0D"
        
        MDBoxLayout:
            orientation: "vertical"
            adaptive_width: True
            spacing: "-5dp" # টাইটেল আর ডটের দূরত্ব কমানোর জন্য
            
            MDLabel:
                text: "ANYLOAD"
                font_style: "H6"
                theme_text_color: "Custom"
                text_color: "#00D2A0" # প্রিমিয়াম টিল কালার
                bold: True
                adaptive_width: True
                halign: "left"
            
            MDLabel:
                text: app.dot_text # main.py থেকে এনিমেটেড টেক্সট নেবে
                font_style: "H5"
                theme_text_color: "Custom"
                text_color: "#00D2A0"
                adaptive_width: True
                halign: "left"
                bold: True
        
        Widget: # এটি টাইটেলকে বামে ঠেলে দেবে

        MDIconButton:
            icon: "dots-vertical"
            theme_text_color: "Custom"
            text_color: "#FFFFFF"
            pos_hint: {"center_y": .5}

    # --- Screen Manager (মেইন কন্টেন্ট) ---
    ScreenManager:
        id: screen_manager
        
        MDScreen:
            name: "home"
            MDLabel:
                text: "HOME TAB"
                halign: "center"
                theme_text_color: "Secondary"
        
        MDScreen:
            name: "tasks"
            MDLabel:
                text: "TASKS TAB"
                halign: "center"
                theme_text_color: "Secondary"
        
        MDScreen:
            name: "library"
            MDLabel:
                text: "LIBRARY TAB"
                halign: "center"
                theme_text_color: "Secondary"
        
        MDScreen:
            name: "configs"
            MDLabel:
                text: "CONFIGS TAB"
                halign: "center"
                theme_text_color: "Secondary"
    
    # --- Bottom Navigation (তোর স্ক্রিনশটের মতো এলাইনমেন্ট) ---
    MDBoxLayout:
        size_hint_y: None
        height: "65dp"
        md_bg_color: "#121212" # নেভিগেশনের জন্য একটু হালকা ডার্ক
        padding: ["5dp", 0, "5dp", 0]

        MDGridLayout:
            cols: 4
            size_hint_x: 1
            
            # Home Tab
            MDBoxLayout:
                orientation: "vertical"
                MDIconButton:
                    icon: "home-variant" if screen_manager.current == "home" else "home-variant-outline"
                    theme_text_color: "Custom"
                    text_color: "#00D2A0" if screen_manager.current == "home" else "#888888"
                    pos_hint: {"center_x": .5}
                    on_release: screen_manager.current = "home"
                MDLabel:
                    text: "Home"
                    halign: "center"
                    font_style: "Caption"
                    theme_text_color: "Custom"
                    text_color: "#00D2A0" if screen_manager.current == "home" else "#888888"

            # Tasks Tab
            MDBoxLayout:
                orientation: "vertical"
                MDIconButton:
                    icon: "download" if screen_manager.current == "tasks" else "download-outline"
                    theme_text_color: "Custom"
                    text_color: "#00D2A0" if screen_manager.current == "tasks" else "#888888"
                    pos_hint: {"center_x": .5}
                    on_release: screen_manager.current = "tasks"
                MDLabel:
                    text: "Tasks"
                    halign: "center"
                    font_style: "Caption"
                    theme_text_color: "Custom"
                    text_color: "#00D2A0" if screen_manager.current == "tasks" else "#888888"

            # Library Tab
            MDBoxLayout:
                orientation: "vertical"
                MDIconButton:
                    icon: "folder-play" if screen_manager.current == "library" else "folder-play-outline"
                    theme_text_color: "Custom"
                    text_color: "#00D2A0" if screen_manager.current == "library" else "#888888"
                    pos_hint: {"center_x": .5}
                    on_release: screen_manager.current = "library"
                MDLabel:
                    text: "Library"
                    halign: "center"
                    font_style: "Caption"
                    theme_text_color: "Custom"
                    text_color: "#00D2A0" if screen_manager.current == "library" else "#888888"

            # Configs Tab
            MDBoxLayout:
                orientation: "vertical"
                MDIconButton:
                    icon: "cog" if screen_manager.current == "configs" else "cog-outline"
                    theme_text_color: "Custom"
                    text_color: "#00D2A0" if screen_manager.current == "configs" else "#888888"
                    pos_hint: {"center_x": .5}
                    on_release: screen_manager.current = "configs"
                MDLabel:
                    text: "Configs"
                    halign: "center"
                    font_style: "Caption"
                    theme_text_color: "Custom"
                    text_color: "#00D2A0" if screen_manager.current == "configs" else "#888888"